{
  "name": "StaticMesh_Standard",
  "assetType": "StaticMesh",
  "description": "標準靜態網格預設，適用於一般環境資產與道具，包含 LOD 與碰撞設定",
  "settings": {
    "naniteEnabled": false,
    "autoComputeLODScreenSize": true,
    "lodCount": 4,
    "lodScreenSizes": [1.0, 0.5, 0.25, 0.125],
    "lodReductionPercent": [0, 50, 75, 90],
    "lightmapResolution": 64,
    "lightmapCoordinateIndex": 1,
    "generateLightmapUVs": true,
    "hasCollision": true,
    "complexCollisionAsSimple": false,
    "autoGenerateCollision": true,
    "generateDistanceFieldAsIfStatic": true,
    "allowCPUAccess": false,
    "supportUniformlyDistributedSampling": false
  },
  "validations": [
    {
      "rule": "hasLODs",
      "condition": "靜態網格應包含至少 2 個 LOD 層級以最佳化遠距離渲染效能",
      "severity": "warning"
    },
    {
      "rule": "hasCollision",
      "condition": "可互動的靜態網格應設定碰撞體",
      "severity": "warning"
    },
    {
      "rule": "hasLightmapUV",
      "condition": "使用靜態光照的網格必須具有 Lightmap UV（UV Channel 1）",
      "severity": "warning"
    },
    {
      "rule": "maxTriangleCount",
      "condition": "LOD0 面數建議不超過 100,000，以維持良好的渲染效能",
      "severity": "info"
    }
  ],
  "requirements": [
    {
      "check": "validGeometry",
      "description": "網格不應包含退化三角形或非流形幾何",
      "required": true
    },
    {
      "check": "uvChannel0",
      "description": "網格必須具有 UV Channel 0 用於材質貼圖",
      "required": true
    },
    {
      "check": "lightmapUV",
      "description": "建議具有不重疊的 UV Channel 1 用於 Lightmap",
      "required": false
    }
  ]
}
