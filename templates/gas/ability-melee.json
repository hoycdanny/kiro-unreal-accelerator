{
  "name": "GA_Melee_LightAttack",
  "description": "近戰輕攻擊技能範本，支援連招系統、體力消耗與冷卻。使用 PlayMontageAndWait 播放攻擊動畫，透過 WaitGameplayEvent 偵測命中事件並套用傷害 Effect。",
  "abilityType": "GameplayAbility",
  "activation": {
    "policy": "OnInputPressed",
    "instancingPolicy": "InstancedPerActor"
  },
  "tags": {
    "abilityTags": ["Ability.Melee.LightAttack"],
    "activationBlockedTags": ["State.Dead", "State.Stunned", "State.Silenced"],
    "cancelAbilitiesWithTag": [],
    "blockAbilitiesWithTag": ["Ability.Movement.Dash"],
    "activationRequiredTags": []
  },
  "cost": {
    "effectName": "GE_Cost_MeleeLightAttack",
