      "parameters": {
        "eventTag": "Event.Montage.AttackHit",
        "onlyTriggerOnce": false,
        "onlyMatchExact": true
      },
      "callbacks": ["EventReceived"]
    }
  ],
  "combo": {
    "enabled": true,
    "maxComboCount": 3,
    "comboWindowTag": "Event.Montage.ComboWindow",
    "comboAnimations": [
      { "index": 0, "section": "Attack1", "description": "第一段橫斬" },
